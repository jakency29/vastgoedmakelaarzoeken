# Leadformulier: e-mailbezorging via Resend. Zonder deze variabelen logt de API-route
# de lead enkel (geen e-mail). Zet de echte waarden als env-variabelen op Vercel.

# API-sleutel van https://resend.com
RESEND_API_KEY=

# Adres waar leads binnenkomen (de eigenaar / makelaarsverdeler)
LEAD_TO_EMAIL=

# Afzender. Moet een geverifieerd domein in Resend zijn, bijv. leads@vastgoedmakelaarzoeken.be
LEAD_FROM_EMAIL=
