# Leadformulier gaat nu via Elfsight (client-side), dus de Resend-variabelen hieronder
# zijn optioneel: enkel nodig als je het eigen /api/lead-formulier opnieuw zou gebruiken.

# API-sleutel van https://resend.com
RESEND_API_KEY=

# Adres waar leads binnenkomen (de eigenaar / makelaarsverdeler)
LEAD_TO_EMAIL=

# Afzender. Moet een geverifieerd domein in Resend zijn, bijv. leads@vastgoedmakelaarzoeken.be
LEAD_FROM_EMAIL=

# Google reviews op de kantoorpagina's: Google Places API-sleutel (server-side).
# Een sleutel volstaat voor alle kantoren; de Place ID's staan per kantoor in src/lib/kantoren.ts.
# Zonder sleutel worden de reviews netjes verborgen.
GOOGLE_PLACES_API_KEY=
